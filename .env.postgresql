#天龙销售宗师 - PostgreSQL 生产环境配置

# === 数据库配置 ===
DATABASE_URL=postgresql://salesadmin:sales123@localhost:5432/SentriKit_sales
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# === 应用配置 ===
APP_NAME=天龙销售宗师
APP_HOST=0.0.0.0
APP_PORT=8877
DEBUG=false

# === SaaS 模式 ===
SALES_USE_SAAS=true
SALES_TENANT_SECRET=your-super-secret-key-change-in-production-min-32-chars

# === LLM 配置 ===
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-your-api-key
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com

# === Stripe 支付（国际）===
# STRIPE_API_KEY=sk_live_xxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# === 支付宝（国内）===
# ALIPAY_APP_ID=2021xxxxx
# ALIPAY_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nxxxxx\n-----END RSA PRIVATE KEY-----
# ALIPAY_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nxxxxx\n-----END PUBLIC KEY-----

# === 微信支付（国内）===
# WECHAT_MCH_ID=1xxxxx
# WECHAT_MCH_SERIAL_NO=XXXXX
# WECHAT_API_KEY=xxxxx
# WECHAT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nxxxxx\n-----END PRIVATE KEY-----

# === 字节跳动电子签 ===
# BYTEDANCE_APP_ID=xxxxx
# BYTEDANCE_APP_SECRET=xxxxx

# === 腾讯电子签 ===
