# ==============================================
# 天龙销售宗师 - 环境变量配置文件
# 复制此文件为 .env 并填入真实值
# ==============================================

# ==============================================
# 1. 基础服务配置
# ==============================================

# API 服务端口和地址
SALES_API_HOST=0.0.0.0
SALES_API_PORT=8877

# API 认证密钥（可选，默认自动生成）
SALES_API_KEY=

# 跳过API认证（开发模式，设为true后无需API Key）
# 生产环境务必设为 false 或删除此行
SALES_SKIP_AUTH=false

# CORS 跨域允许来源（生产环境建议配置）
# 多个来源用逗号分隔，例如: https://your-domain.com,https://admin.your-domain.com
SALES_CORS_ORIGINS=

# API 限流（每分钟请求次数，默认 100）
# 设置为 0 关闭限流
SALES_RATE_LIMIT=100

# SaaS 模式开关（生产环境设为 true）
SALES_USE_SAAS=false

# 租户密钥（SaaS 模式必需）
SALES_TENANT_SECRET=tianlong-sales-secret-key-2024

# ==============================================
# 2. 数据库配置
# ==============================================

# 数据库类型：sqlite | mysql | postgres
DB_TYPE=sqlite

# PostgreSQL 配置 (DB_TYPE=postgres 时使用)
DATABASE_URL=postgresql://salesadmin:sales123@localhost:5432/tianlong_sales

# MySQL 配置 (DB_TYPE=mysql 时使用)
MYSQL_URL=mysql+pymysql://salesadmin:sales123@localhost:3306/tianlong_sales

# ==============================================
# 3. LLM 集成配置
# ==============================================

# LLM API 密钥（通用）
LLM_API_KEY=

# OpenAI 配置
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# DeepSeek 配置
DEEPSEEK_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Claude 配置
CLAUDE_API_KEY=
CLAUDE_API_BASE=https://api.anthropic.com/v1
CLAUDE_MODEL=claude-3-opus-20240229

# 通义千问配置
QWEN_API_KEY=
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-max

# Ollama 本地模型配置
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# ==============================================
# 4. 消息触达配置
# ==============================================

# 邮件 SMTP 配置
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# 阿里云短信配置
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=天龙销售
ALIYUN_SMS_TEMPLATE_CODE=SMS_123456789

# 腾讯云短信配置
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=1400000000
TENCENT_SMS_SIGN_NAME=天龙销售
TENCENT_SMS_TEMPLATE_ID=123456

# 企业微信配置
QYWX_CORP_ID=
QYWX_AGENT_ID=
QYWX_SECRET=

# 钉钉配置
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=

# 飞书配置
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# ==============================================
# 5. 支付集成配置
# ==============================================

# Stripe 配置
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# 支付宝配置
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# 微信支付配置
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_CERT_PATH=

# ==============================================
# 6. 电子签章配置
# ==============================================

# 字节电子签配置
BYTEDANCE_APP_ID=
BYTEDANCE_APP_SECRET=

# 腾讯电子签配置
TENCENT_ESS_APP_ID=
TENCENT_ESS_SECRET_KEY=

# ==============================================
# 7. 其他配置
# ==============================================

# 存储目录（默认为项目根目录下的 _data）
DATA_DIR=

# 调试模式（生产环境设为 false）
DEBUG=true
